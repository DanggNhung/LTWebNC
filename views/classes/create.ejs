<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thêm lớp</title>
</head>
<body>
    <h1>Thêm lớp mới</h1>
    <form 
        action="/classes/create" 
        method="POST">
        <label>
            Mã lớp:
        </label>
        <br>

        <input 
            type="text"
            name="class_code"
            required>


        <br><br>



        <label>
            Tên lớp:
        </label>

        <br>

        <input 
            type="text"
            name="class_name"
            required>


        <br><br>



        <label>
            Mô tả:
        </label>

        <br>

        <textarea 
            name="description"
            rows="4"
            cols="40">
        </textarea>


        <br><br>



        <button type="submit">
            Lưu
        </button>


        <a href="/classes">
            Quay lại
        </a>


    </form>
</body>
</html>