<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết tài khoản</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .container {
            max-width: 700px;
            margin-top: 50px;
        }

        .card {
            border-radius: 10px;
        }

        .info-label {
            font-weight: bold;
            width: 180px;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h3 class="mb-0">Chi tiết tài khoản</h3>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <td class="info-label">ID</td>
                    <td><%= account.id %></td>
                </tr>
                <tr>
                    <td class="info-label">Tên đăng nhập</td>
                    <td><%= account.username %></td>
                </tr>
                <tr>
                    <td class="info-label">Họ và tên</td>
                    <td><%= account.fullname %></td>
                </tr>
                <tr>
                    <td class="info-label">Quyền</td>
                    <td>
                        <% if(account.role === "admin"){ %>
                            <span class="badge bg-danger">
                                Admin
                            </span>
                        <% } else if(account.role === "teacher"){ %>
                            <span class="badge bg-warning text-dark">
                                Giảng viên
                            </span>
                        <% } else { %>
                            <span class="badge bg-success">
                                Sinh viên
                            </span>
                        <% } %>
                    </td>
                </tr>
                <tr>
                    <td class="info-label">Ngày tạo</td>
                    <td>
                        <%= new Date(account.created_at).toLocaleString("vi-VN") %>
                    </td>
                </tr>
            </table>
            <div class="d-flex justify-content-between mt-4">
                <a href="/accounts" class="btn btn-secondary">
                    ← Quay lại
                </a>
                <a
                    href="/accounts/edit/<%= account.id %>"
                    class="btn btn-warning"
                >
                    Chỉnh sửa
                </a>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>